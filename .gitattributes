# Path-based git attributes — keep Packagist tarball lean.
# https://www.kernel.org/pub/software/scm/git/docs/gitattributes.html

# Internal agent guides — never ship.
/CLAUDE.md            export-ignore
/src/CLAUDE.md        export-ignore
/src/Query/CLAUDE.md  export-ignore
/src/Schema/CLAUDE.md export-ignore
/tests/CLAUDE.md      export-ignore

# Tests + fixtures (heavy, dev-only).
/tests                export-ignore

# CI + repo hygiene.
/.github              export-ignore
/.gitattributes       export-ignore
/.gitignore           export-ignore
/.editorconfig        export-ignore

# Tooling configs.
/phpunit.xml          export-ignore
/phpstan.neon         export-ignore
/pint.json            export-ignore
/rector.php           export-ignore

# Build / lock artifacts.
/build                export-ignore
/composer.lock        export-ignore
