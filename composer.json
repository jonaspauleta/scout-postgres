{
    "name": "apex-scout/scout-postgres",
    "description": "Native Postgres full-text search + pg_trgm engine for Laravel Scout.",
    "keywords": ["laravel", "scout", "postgres", "full-text-search", "pg_trgm"],
    "homepage": "https://github.com/jonaspauleta/scout-postgres",
    "license": "MIT",
    "authors": [
        { "name": "João Paulo Santos", "email": "jonaspauleta2@gmail.com", "role": "Developer" }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "laravel/scout": "^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^5.0",
        "pestphp/pest-plugin-laravel": "^5.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "ApexScout\\ScoutPostgres\\": "src/",
            "ApexScout\\ScoutPostgres\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApexScout\\ScoutPostgres\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint",
        "refactor": "vendor/bin/rector --no-diffs",
        "quality": [
            "@refactor",
            "@format",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "extra": {
        "laravel": {
            "providers": ["ApexScout\\ScoutPostgres\\ScoutPostgresServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
